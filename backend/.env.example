# Copy to .env and fill in values.
# For Docker, the root .env is injected — you only need this for running the backend directly.

DATABASE_URL=postgresql+asyncpg://applaut:applaut_dev@localhost:5432/applaut
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

OPENAI_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BACKEND_CORS_ORIGINS=["http://localhost:5173"]
BACKEND_PORT=8000
