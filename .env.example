# ============================================================
# Applaut — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
# For local dev without Docker: use localhost
# Docker Compose overrides this to use the postgres service name
DATABASE_URL=postgresql+asyncpg://applaut:applaut_dev@localhost:5432/applaut

# --- JWT ---
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- AI providers ---
OPENAI_API_KEY=

# --- Google OAuth (optional in V1) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Backend server ---
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
BACKEND_PORT=8000

# --- Frontend (Vite picks up VITE_ prefixed vars) ---
VITE_API_BASE_URL=http://localhost:8000
