# ============================================================
# Applaut — PRODUCTION environment variables
# Copy to .env.production on the Oracle VM and fill in values.
# Never commit .env.production to version control.
# ============================================================

# --- Postgres (used by docker-compose.prod.yml) ---
POSTGRES_DB=applaut
POSTGRES_USER=applaut
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- JWT ---
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=applaut-documents
R2_PUBLIC_URL=https://your-r2-public-url

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- CORS: Cloudflare Pages URL ---
BACKEND_CORS_ORIGINS=["https://applaut.pages.dev","https://app.applaut.lvamo.com"]

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
